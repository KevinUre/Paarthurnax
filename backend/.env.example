# Server
PORT=3000

# CORS
# true  = enforce allowlist in CORS_ORIGIN
# false = permissive mode (allow all origins) for local debugging
CORS_ENABLED=true

# In non-production this defaults to true and allows any localhost/127.0.0.1 origin.
# In production this defaults to false.
CORS_ALLOW_LOCALHOST=true

# Comma-separated allowlist of exact origins (scheme + host + port, no path).
# Example local:
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Example production:
# CORS_ORIGIN=https://paarthurnax.example.org
# Multiple:
# CORS_ORIGIN=https://paarthurnax.example.org,https://staging-paarthurnax.example.org

# Auth session durations
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# CSP defaults to false for local dev convenience.
CSP_ENABLED=false

# Space-separated connect-src values when CSP is enabled.
# Local dev example:
CSP_CONNECT_SRC='self' http://localhost:3000 http://localhost:5173 ws://localhost:5173
# Production example:
# CSP_CONNECT_SRC='self' https://paarthurnax.example.org https://api.paarthurnax.example.org

# Optional full CSP override (advanced).
# CSP_POLICY=default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.paarthurnax.example.org
