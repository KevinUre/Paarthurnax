PORT=3000

# CORS
CORS_ENABLED=true
CORS_ALLOW_LOCALHOST=false
CORS_ORIGIN=https://your-domain.example

# Auth
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# CSP
CSP_ENABLED=true
CSP_CONNECT_SRC='self' https://your-domain.example
# Optional advanced override:
# CSP_POLICY=default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://your-domain.example
